# TEOS Production Environment Configuration
# Copy to .env and adjust values

# General
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_32_CHARS
TIMEZONE=Asia/Tehran

# Database
DATABASE_URL=postgresql+asyncpg://teos:STRONG_PASSWORD@postgres:5432/teos_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://:REDIS_STRONG_PASSWORD@redis:6379/0
REDIS_PASSWORD=REDIS_STRONG_PASSWORD

# Telegram Bot
BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
BOT_WEBHOOK_URL=https://your-domain.com
BOT_WEBHOOK_PATH=/webhook
USE_WEBHOOK=true
POLLING_TIMEOUT=30

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["https://your-domain.com","https://admin.your-domain.com"]

# Security
BCRYPT_ROUNDS=12
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
RATE_LIMIT_PER_USER=100/minute
ADMIN_IDS=[123456789,987654321]

# AI
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo
AI_CONFIDENCE_THRESHOLD=0.7
AI_ENABLED=true

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage
S3_BUCKET=teos-storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Payment
PAYMENT_MOCK=false
PAYMENT_CALLBACK_URL=https://your-domain.com/api/webhook/payment
PAYMENT_WEBHOOK_SECRET=CHANGE_ME
PAYMENT_GATEWAY_URL=https://api.zarinpal.com

# SMTP (for email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@teos.local
SMTP_TLS=true

# SMS (Kavenegar example)
SMS_API_KEY=YOUR_KAVENEGAR_API_KEY

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PASSWORD=admin

# Auto Update
AUTO_UPDATE_ENABLED=false
UPDATE_CHECK_INTERVAL_HOURS=24
GIT_REPO_URL=https://github.com/yourorg/teos.git

# Backup
BACKUP_CRON_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=7

# Feature Flags
FEATURE_MUSIC_ENABLED=true
FEATURE_VPN_ENABLED=true
FEATURE_WALLET_ENABLED=true
FEATURE_TICKET_ENABLED=true
FEATURE_PLUGINS_ENABLED=true
